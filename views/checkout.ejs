    <!DOCTYPE html>
    <html lang="en">
    <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GadgetHub Checkout</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/checkout.css">

    <!-- Razorpay -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    </head>

    <body>

    <!-- ===== HEADER ===== -->
    <nav class="navbar navbar-expand-lg px-4 py-3">
        <div class="container">

            <a class="navbar-brand text-white" href="/home">GADGETHUB</a>

            <div class="ms-auto d-flex align-items-center gap-4">

                <!-- Steps -->
                <div class="d-none d-md-flex gap-3">

                    <div class="step">
                        <div class="step-circle">1</div>
                        <span class="small">CART</span>
                    </div>

                    <div class="step active">
                        <div class="step-circle">2</div>
                        <span class="small">CHECKOUT</span>
                    </div>

                    <div class="step">
                        <div class="step-circle">3</div>
                        <span class="small">PAYMENT</span>
                    </div>

                </div>

                <!-- Lock -->
                <i class="fa-solid fa-lock text-info"></i>

            </div>

        </div>
    </nav>

    <!-- ===== MAIN ===== -->
    <div class="container py-5">

        <div class="row g-4">

            <!-- LEFT -->
            <div class="col-lg-8">

                <!-- Addresses -->
                <div class="glass-card mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6>Select Delivery Address</h6>
                        <button class="btn btn-outline-info btn-sm" id="addAddressBtn">
                            + Add New
                        </button>
                    </div>

                    <% if(addresses.length === 0) { %>
                        <p class="text-secondary">No addresses saved. Add one below.</p>
                    <% } else { %>
                        <% addresses.forEach(address => { %>
                            <div class="address-card mb-2 p-3 rounded border border-secondary" 
                                onclick="selectAddress('<%= address._id %>')"
                                id="addr-<%= address._id %>">
                                <div class="d-flex justify-content-between">
                                    <strong class="text-info"><%= address.fullName %></strong>
                                    <% if(address.isDefault) { %>
                                        <span class="badge bg-info">Default</span>
                                    <% } %>
                                </div>
                                <small class="text-secondary">
                                    <%= address.address %>, <%= address.city %>, 
                                    <%= address.state %> - <%= address.pincode %>
                                </small><br>
                                <small class="text-secondary">📞 <%= address.phone %></small>
                            </div>
                        <% }) %>
                    <% } %>

                    <input type="hidden" id="selectedAddress" value="">
                </div>
            

                <!-- Payment Method -->
                <div class="glass-card">
                    <h6 class="mb-3">Payment Method</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="payment-option text-center" onclick="selectPayment('COD')" id="pay-COD">
                                <i class="fa-solid fa-money-bill-wave"></i>
                                <div>Cash on Delivery</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="payment-option text-center" onclick="selectPayment('online')" id="pay-online">
                                <i class="fa-solid fa-credit-card"></i>
                                <div>Online Payment</div>
                            </div>
                        </div>
                    </div>
                    <input type="hidden" id="selectedPayment" value="">
                </div>
            </div>

            <!-- RIGHT -->
            <div class="col-lg-4">
                <div class="summary-card">
                    <h6 class="mb-3">Order Summary</h6>

                    <% items.forEach(item => { %>
                        <div class="summary-line">
                            <span><%= item.product.name %></span>
                            <span>₹<%= item.product.finalPrice %> × <%= item.quantity %></span>
                        </div>
                    <% }) %>

                    <hr>

                    <div class="summary-line">
                        <span>Subtotal</span>
                        <span>₹<%= total %></span>
                    </div>
                    <div class="summary-line">
                        <span>Shipping</span>
                        <span class="text-info">FREE</span>
                    </div>

                    <hr>

                    <% if(appliedCoupon) { %>
                        <div class="summary-line text-success">
                            <span>Coupon (<%= appliedCoupon.code %>)</span>
                            <span>-₹<%= appliedCoupon.discountAmount %></span>
                        </div>
                    <% } %>

                    <div class="summary-line total">
                        <span>Total</span>
                        <span id="checkoutTotal">₹<%= finalTotal %></span>
                    </div>

                    <button class="place-btn mt-3" id="placeOrderBtn">PLACE ORDER</button>
                </div>
            </div>
        </div>

    </div>

    <!-- ===== FOOTER ===== -->
    <footer class="pt-5 pb-4">
        <div class="container">

            <div class="row g-4">

                <div class="col-md-4">
                    <h5 class="text-white">GadgetHub</h5>
                    <p class="small text-secondary">
                        Curating the world’s most advanced technology into a seamless obsidian experience.
                    </p>
                </div>

                <div class="col-md-4">
                    <h6 class="text-info small">QUICK LINKS</h6>
                    <ul class="list-unstyled small">
                        <li><a href="#" class="text-secondary text-decoration-none">Support</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none">Shipping</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none">Return Policy</a></li>
                    </ul>
                </div>

                <div class="col-md-4">
                    <h6 class="text-info small">SECURITY</h6>
                    <div class="d-flex gap-2">
                        <span class="badge bg-dark">VISA</span>
                        <span class="badge bg-dark">AMEX</span>
                        <span class="badge bg-dark">PAYPAL</span>
                    </div>
                </div>

            </div>

            <hr style="border-color:#1e293b;">

            <div class="d-flex justify-content-between small text-secondary flex-column flex-md-row">
                <span>© 2024 GadgetHub. Engineered for excellence.</span>
                <div>
                    <a href="#" class="text-secondary me-3 text-decoration-none">Privacy</a>
                    <a href="#" class="text-secondary text-decoration-none">Terms</a>
                </div>
            </div>

        </div>
    </footer>

    <script>
        const RAZORPAY_KEY = "<%= process.env.RAZORPAY_KEY_ID %>";
        const USER_NAME     = "<%= user.name %>";
        const USER_EMAIL    = "<%= user.email %>";
        const USER_PHONE     = "<%= user.phone || '' %>";
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/checkout.js"></script>
    </body>
    </html>