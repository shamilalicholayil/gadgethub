<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/shop.css">
</head>
<body>

<%- include("./partials/userNavbar") %>

<div class="container py-5">
    <h4 class="text-info fw-bold mb-4">My Wishlist</h4>

    <% if(!wishlist || wishlist.products.length === 0) { %>
        <div class="glass p-5 text-center text-secondary">
            <i class="fa fa-heart fa-3x mb-3"></i>
            <p>Your wishlist is empty. <a href="/shop" class="text-info">Browse products</a></p>
        </div>
    <% } else { %>
        <div class="row g-4">
            <% wishlist.products.forEach(item => { %>
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card glass p-4 h-100">
                        <img src="<%= item.images[0].url %>"
                             class="mb-3" height="200"
                             style="object-fit:cover;border-radius:10px;width:100%">
                        <h5 class="fw-bold text-info mb-2"><%= item.name %></h5>
                        <p class="text-secondary mb-3">₹<%= item.finalPrice %></p>
                        <div class="d-flex gap-2 mt-auto">
                            <a href="/product/<%= item._id %>"
                            class="btn btn-sm btn-info w-100">
                                View
                            </a>
                            <button class="btn btn-sm btn-outline-info addToCartBtn"
                                    data-id="<%= item._id %>">
                                <i class="fa fa-cart-plus"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger removeWishlistBtn"
                                    data-id="<%= item._id %>">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include("./partials/userFooter") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/wishlist.js"></script>
</body>
</html>