<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Responsive Admin Order Details</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
    <link rel="stylesheet" href="/css/adminOrderDetails.css">
</head>

<body>

  <div class="d-flex">

    <!-- SIDEBAR -->
    <div class="sidebar glass p-4">

      <h3 class="fw-bold mb-4">
        <i class="fa-solid fa-layer-group custom-color"></i>
        Admin
      </h3>

      <a href="#" class="sidebar-link">
        <i class="fa-solid fa-chart-line"></i>
        Dashboard
      </a>

      <a href="#" class="sidebar-link">
        <i class="fa-solid fa-box"></i>
        Products
      </a>

      <a href="#" class="sidebar-link active">
        <i class="fa-solid fa-bag-shopping"></i>
        Orders
      </a>

      <a href="#" class="sidebar-link">
        <i class="fa-solid fa-users"></i>
        Customers
      </a>

      <a href="#" class="sidebar-link">
        <i class="fa-solid fa-gear"></i>
        Settings
      </a>

    </div>

    <!-- MAIN -->
    <div class="main-content">

      <!-- MOBILE TOPBAR -->
      <div class="mobile-topbar justify-content-between align-items-center mb-4">

        <h4 class="fw-bold mb-0">
          <i class="fa-solid fa-bag-shopping custom-color"></i>
          Orders
        </h4>

        <button class="btn btn-outline-info">
          <i class="fa-solid fa-bars"></i>
        </button>

      </div>

      <!-- TOP HEADER -->
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">

        <div>
          <h2 class="fw-bold">Order Details</h2>
          <p class="custom-color mb-0">
            Monitor and manage customer order status
          </p>
        </div>

        <div class="d-flex gap-3 top-actions">

          <input
            type="text"
            class="form-control custom-input"
            placeholder="Search order..."
          >

          <button class="btn btn-info fw-semibold px-4">
            Update Status
          </button>

        </div>

      </div>

      <!-- SUMMARY -->
      <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">
          <div class="glass summary-card">
            <div class="summary-label">Order ID</div>
            <div class="summary-value">#ORD-45821</div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="glass summary-card">
            <div class="summary-label">Order Date</div>
            <div class="summary-value">14 May 2026</div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="glass summary-card">
            <div class="summary-label">Payment</div>
            <div class="summary-value">Razorpay</div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="glass summary-card">
            <div class="summary-label">Current Status</div>

            <span class="status-badge status-delivered">
              <i class="fa-solid fa-circle-check"></i>
              Delivered
            </span>

          </div>
        </div>

      </div>

      <!-- CUSTOMER + STATUS -->
      <div class="row g-4 mb-4">

        <!-- CUSTOMER -->
        <div class="col-lg-6">

          <div class="glass p-4 h-100">

            <h5 class="mb-4">
              <i class="fa-solid fa-user custom-color me-2"></i>
              Customer Details
            </h5>

            <div class="mb-3">
              <small class="custom-color">Customer Name</small>
              <h6 class="mt-1">Shamil Ali</h6>
            </div>

            <div class="mb-3">
              <small class="custom-color">Email Address</small>
              <h6 class="mt-1">shamil@example.com</h6>
            </div>



            <div>
              <small class="custom-color">Shipping Address</small>

              <h6 class="mt-2 lh-lg">
                AK House <br>
                Trikkandiyur, Tirur <br>
                Kerala, India
              </h6>
            </div>

          </div>

        </div>

        <!-- STATUS MAP -->
        <div class="col-lg-6">

          <div class="glass p-4 h-100">

            <div class="d-flex justify-content-between align-items-center mb-3">

              <h5 class="mb-0">
                <i class="fa-solid fa-truck-fast custom-color me-2"></i>
                Order Status
              </h5>

              <select class="form-select custom-input w-auto">
                <option>Delivered</option>
                <option>Out For Delivery</option>
                <option>Shipped</option>
                <option>Processing</option>
                <option>Cancelled</option>
              </select>

            </div>

            <!-- TIMELINE -->
            <div class="timeline">

              <div class="timeline-step active">
                <div class="timeline-dot"></div>

                <div class="timeline-title">
                  Order Confirmed
                </div>

                <div class="timeline-date">
                  14 May 2026 - 09:30 AM
                </div>
              </div>

              <div class="timeline-step active">
                <div class="timeline-dot"></div>

                <div class="timeline-title">
                  Packed Successfully
                </div>

                <div class="timeline-date">
                  14 May 2026 - 11:10 AM
                </div>
              </div>

              <div class="timeline-step active">
                <div class="timeline-dot"></div>

                <div class="timeline-title">
                  Shipped
                </div>

                <div class="timeline-date">
                  15 May 2026 - 08:00 AM
                </div>
              </div>

              <div class="timeline-step active">
                <div class="timeline-dot"></div>

                <div class="timeline-title">
                  Out For Delivery
                </div>

                <div class="timeline-date">
                  16 May 2026 - 10:15 AM
                </div>
              </div>

              <div class="timeline-step active">
                <div class="timeline-dot"></div>

                <div class="timeline-title">
                  Delivered
                </div>

                <div class="timeline-date">
                  16 May 2026 - 04:30 PM
                </div>
              </div>

            </div>

          </div>

        </div>

      </div>

      <!-- PRODUCTS -->
      <div class="glass p-4 mb-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

          <h5 class="mb-0">
            <i class="fa-solid fa-cart-shopping custom-color me-2"></i>
            Ordered Products
          </h5>

          <span class="badge bg-info text-dark px-3 py-2">
            2 Items
          </span>

        </div>

        <div class="table-responsive">

          <table class="table table-transparant align-middle">

            <thead>
              <tr>
                <th>Image</th>
                <th>Product</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Total</th>
              </tr>
            </thead>

            <tbody>

              <tr>

                <td>
                  <img
                    src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=400"
                    class="product-img"
                    alt=""
                  >
                </td>

                <td>
                  Nike Air Max Sneakers
                </td>

                <td>
                  ₹4,999
                </td>

                <td>
                  2
                </td>

                <td>
                  ₹9,998
                </td>

              </tr>

              <tr>

                <td>
                  <img
                    src="https://images.unsplash.com/photo-1525966222134-fcfa99b8ae77?q=80&w=400"
                    class="product-img"
                    alt=""
                  >
                </td>

                <td>
                  Running Shoes
                </td>

                <td>
                  ₹2,499
                </td>

                <td>
                  1
                </td>

                <td>
                  ₹2,499
                </td>

              </tr>

            </tbody>

          </table>

        </div>

      </div>

      <!-- PAYMENT SUMMARY -->
      <div class="row justify-content-end">

        <div class="col-lg-4 col-md-6">

          <div class="glass p-4">

            <h5 class="mb-4">
              <i class="fa-solid fa-receipt custom-color me-2"></i>
              Payment Summary
            </h5>

            <div class="price-row">
              <span>Subtotal</span>
              <span>₹12,497</span>
            </div>

            <div class="price-row">
              <span>Shipping</span>
              <span>₹99</span>
            </div>

            <div class="price-row">
              <span>Tax</span>
              <span>₹250</span>
            </div>

            <hr class="border-secondary">

            <div class="price-row total-row">
              <span>Total</span>
              <span>₹12,846</span>
            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

</body>
</html>