<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Order Details</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
  <link rel="stylesheet" href="/css/adminSidebar.css">
    <link rel="stylesheet" href="/css/orderDetails.css">
</head>

<body>

  <div class="d-flex">

    <!-- SIDEBAR -->
    <%- include("../partials/adminSidebar") %>

    <!-- MAIN -->
    <div class="main-content">

      <!-- MOBILE TOPBAR -->
      <div class="mobile-topbar justify-content-between align-items-center mb-4">

        <h4 class="fw-bold mb-0">
          <i class="fa-solid fa-bag-shopping custom-color"></i>
          Orders
        </h4>

      </div>

      <!-- TOP HEADER -->
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">

        <div>
          <h2 class="fw-bold">Order Details</h2>
          <p class="custom-color mb-0">
            Monitor and manage customer order status
          </p>
        </div>

      </div>

      <!-- SUMMARY -->
      <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">
          <div class="glass summary-card">
            <div class="summary-label">Order ID</div>
            <div class="summary-value">#<%= order._id.toString().slice(-6).toUpperCase() %></div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="glass summary-card">
            <div class="summary-label">Order Date</div>
            <div class="summary-value"><%= order.createdAt.toDateString() %></div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="glass summary-card">
            <div class="summary-label">Payment</div>
            <div class="summary-value"><%= order.paymentMethod.toUpperCase() %></div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="glass summary-card">
            <div class="summary-label">Current Status</div>

            <span class="status-badge status-delivered">
              <i class="<%= order.paymentStatus === 'paid' ? 'fa-solid fa-circle-check' : '' %>"></i>
              <%= order.paymentStatus.toUpperCase() %>
            </span>

          </div>
        </div>

      </div>

      <!-- CUSTOMER + STATUS -->
      <div class="row g-4 mb-4">

        <!-- CUSTOMER -->
        <div class="col-lg-6">

          <div class="glass p-4 h-100">

            <div class="d-flex justify-content-between">

                <h5 class="mb-4">
                <i class="fa-solid fa-user custom-color me-2"></i>
                Customer Details
                </h5>

                <button class="btn btn-outline-info" id="downloadInvoice">
                    <i class="fa fa-download"></i> Download Invoice
                </button>

            </div>

            <div class="mb-3">
              <small class="custom-color">Customer Name</small>
              <h6 class="mt-1"><%= order.user.name %></h6>
            </div>

            <div class="mb-3">
              <small class="custom-color">Email Address</small>
              <h6 class="mt-1"><%= order.user.email %></h6>
            </div>



            <div>
              <small class="custom-color">Shipping Address</small>

              <h6 class="mt-2 lh-lg">
                <%= order.address.address %> <br>
                <%= order.address.city %> <br>
                <%= order.address.state %> - <%= order.address.pincode %>
              </h6>
            </div>

          </div>

        </div>

        <!-- STATUS MAP -->
        <div class="col-lg-6">

          <div class="glass p-4 h-100">

            <div class="d-flex justify-content-between align-items-center mb-3">

              <h5 class="mb-0">
                <i class="fa-solid fa-truck-fast custom-color me-2"></i>
                Order Status
              </h5>

              <select class="form-select custom-input w-auto" id="statusSelect" data-id="<%= order._id %>">
                  <option value="pending" <%= order.orderStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                  <option value="processing" <%= order.orderStatus === 'processing' ? 'selected' : '' %>>Processing</option>
                  <option value="shipped" <%= order.orderStatus === 'shipped' ? 'selected' : '' %>>Shipped</option>
                  <option value="delivered" <%= order.orderStatus === 'delivered' ? 'selected' : '' %>>Delivered</option>
                  <option value="cancelled" <%= order.orderStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                  <option value="returned" <%= order.orderStatus === 'returned' ? 'selected' : '' %>>Returned</option>
              </select>

            </div>

            <!-- TIMELINE -->
            <div class="timeline" id="timeline">

            </div>

          </div>

        </div>

      </div>

      <!-- PRODUCTS -->
      <div class="glass p-4 mb-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

          <h5 class="mb-0">
            <i class="fa-solid fa-cart-shopping custom-color me-2"></i>
            Ordered Products
          </h5>

          <span class="badge bg-info text-dark px-3 py-2">
            <%= order.items.length %> Items
          </span>

        </div>

        <div class="table-responsive">

          <table class="table table-transparant align-middle">

            <thead>
              <tr>
                <th>Image</th>
                <th>Product</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Total</th>
              </tr>
            </thead>

            <tbody>

              <% order.items.forEach(item => { %>
                    <tr>
                        <td><img src="<%= item.product.images[0].url %>" class="product-img"></td>
                        <td><%= item.product.name %></td>
                        <td>₹<%= item.price %></td>
                        <td><%= item.quantity %></td>
                        <td>₹<%= item.quantity * item.price %></td>
                    </tr>
              <% }) %>

            </tbody>

          </table>

        </div>

      </div>

      <!-- PAYMENT SUMMARY -->
      <div class="row justify-content-end">

        <div class="col-lg-4 col-md-6">

          <div class="glass p-4">

            <h5 class="mb-4">
              <i class="fa-solid fa-receipt custom-color me-2"></i>
              Payment Summary
            </h5>

            <div class="price-row">
              <span>Subtotal</span>
              <span>₹<%= order.totalAmount + order.discount %></span>
            </div>

            <div class="price-row">
              <span>Shipping</span>
              <span>Free</span>
            </div>

            <div class="price-row">
              <span>Discount</span>
              <span>-₹<%= order.discount %></span>
            </div>

            <div class="price-row">
              <span>Tax</span>
              <span>₹0</span>
            </div>

            <hr class="border-secondary">

            <div class="price-row total-row">
              <span>Total</span>
              <span>₹<%= order.totalAmount %></span>
            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const orderStatus = "<%- order.orderStatus %>";
        const orderId = "<%- order._id %>";
        const orderTotal = <%- order.totalAmount %>;
        const orderDiscount = <%- order.discount %>;
        const orderPayment = "<%- order.paymentMethod.toUpperCase() %>";
        const customerName = "<%- order.user.name %>";
        const customerEmail = "<%- order.user.email %>";
        const orderItems = <%- JSON.stringify(order.items.map(i => ({
            name: i.product.name,
            quantity: i.quantity,
            price: i.price
        }))) %>;
        const cancelledAtStatus = "<%- order.cancelledAtStatus || '' %>";
    </script>
    <script src="/js/adminOrderDetails.js"></script>
</body>
</html>