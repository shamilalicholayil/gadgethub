<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brands</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
    <link rel="stylesheet" href="/css/adminSidebar.css">
    <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
    <div class="d-flex">
        <%- include("../partials/adminSidebar") %>
        
        <div class="flex-grow-1 p-4">
            <div class="d-flex justify-content-between align-items-center p-4">
                <h4 class="text-info fw-bold">Brands</h4>
                <div class="d-flex justify-content-center gap-2">
                    <input type="text" 
                            id="searchInput"
                            placeholder="Search Brand" 
                            class="form-control bg-black custom-input border-secondary w-50">
                    <button type="button" class="btn btn-info"
                            data-bs-toggle="modal" data-bs-target="#addBrandModal"
                            >+ Add Brand</button>
                </div>
            </div>

            <div class="container mt-4">
                <div class="row g-4" id="brandTableBody"> </div>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="toast" class="toast align-items-center text-white border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" 
                        data-bs-dismiss="toast">
                </button>
            </div>
        </div>
    </div>

    <!-- Add Brand Model -->
    <div class="modal fade" id="addBrandModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content glass-modal text-light">

                <div class="modal-header border-0">
                    <h5 class="modal-title text-info fw-bold">
                        <i class="fa fa-tag me-2"></i>Add Brand
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="text" 
                        id="brandNameInput" 
                        class="form-control custom-input" 
                        placeholder="Enter brand name">
                    <p id="brandError" class="text-danger mt-2 d-none"></p>
                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-info" 
                            id="saveBrandBtn">Save</button>
                </div>

            </div>
        </div>
    </div>

    <!-- Edit Brand Model -->
    <div class="modal fade" id="editBrandModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content glass-modal text-light">

                <div class="modal-header border-0">
                    <h5 class="modal-title text-info fw-bold">
                        <i class="fa fa-tag me-2"></i>Edit Brand
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                    data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="text"
                            id="editBrandInput"
                            class="form-control custom-input"
                            value="">
                    <p id="editBrandError" class="text-danger mt-2 d-none"></p>
                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-info"
                    id="saveEditBrandBtn">Save</button>
                </div>

            </div>
        </div>
     </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/brand.js"></script>
</body>
</html>