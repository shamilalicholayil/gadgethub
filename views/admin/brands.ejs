<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brands</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
    <div class="d-flex">
        <%- include("../partials/adminSidebar") %>
        
        <div class="flex-grow-1 p-4">
            <div class="d-flex justify-content-between align-items-center p-4">
                <h4 class="text-info fw-bold">Brands</h4>
                <button type="button" class="btn btn-info"
                        data-bs-toggle="modal" data-bs-target="#addBrandModal"
                        >+ Add Brand</button>
            </div>

            <div class="container mt-4">
                <div class="row g-4" id="brandTableBody">

                    <% if (brands.length === 0) { %>
                        <div class="text-center py-5 text-secondary">Brand not found.</div>
                    <% } else { %>

                        <% brands.forEach(brand => { %>

                            <div class="col-md-4">
                                <div class="card glass p-4 h-100">

                                    <h5 class="fw-bold text-info mb-3"><%= brand.name %></h5>

                                    <% if (brand.isActive) { %>
                                        <span class="badge bg-success mb-3">Active</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary mb-3">Inactive</span>
                                    <% } %>

                                    <div class="d-flex gap-2 mt-auto">

                                        <button type="button"
                                            class="btn btn-sm btn-outline-info w-100 editBtn"
                                            data-id="<%= brand._id %>"
                                            data-name="<%= brand.name %>">
                                            <i class="fa fa-edit"></i> Edit
                                        </button>

                                        <button type="button"
                                            class="btn btn-sm btn-outline-danger w-100 deleteBtn"
                                            data-id="<%= brand._id %>"
                                            data-active="<%= brand.isActive %>">
                                            <i class="fa fa-power-off"></i>
                                            <% if (brand.isActive) { %>
                                                Disable
                                            <% } else { %>
                                                Enable
                                            <% } %>
                                        </button>

                                    </div>

                                </div>
                            </div>

                        <% }) %>

                    <% } %>

                </div>
            </div>
        </div>
    </div>

    <!-- Add Brand Model -->
    <div class="modal fade" id="addBrandModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content glass-modal text-light">

                <div class="modal-header border-0">
                    <h5 class="modal-title text-info fw-bold">
                        <i class="fa fa-tag me-2"></i>Add Brand
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="text" 
                        id="brandNameInput" 
                        class="form-control custom-input" 
                        placeholder="Enter brand name">
                    <p id="brandError" class="text-danger mt-2 d-none"></p>
                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-info" 
                            id="saveBrandBtn">Save</button>
                </div>

            </div>
        </div>
    </div>

    <!-- Edit Brand Model -->
    <div class="modal fade" id="editBrandModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content glass-modal text-light">

                <div class="modal-header border-0">
                    <h5 class="modal-title text-info fw-bold">
                        <i class="fa fa-tag me-2"></i>Edit Brand
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                    data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="text"
                            id="editBrandInput"
                            class="form-control custom-input"
                            value="">
                    <p id="editBrandError" class="text-danger mt-2 d-none"></p>
                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-info"
                    id="saveEditBrandBtn">Save</button>
                </div>

            </div>
        </div>
     </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/brand.js"></script>
</body>
</html>