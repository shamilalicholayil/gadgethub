<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users — GadgetHub Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
    <link rel="stylesheet" href="/css/adminSidebar.css">
    <link href="/css/styles.css" rel="stylesheet">

</head>
<body>

    <div class="d-flex admin-layout">
        <%- include("../partials/adminSidebar") %>

        <div class="admin-content">

            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <h4 class="text-info fw-bold mb-0">Users</h4>
                        <input type="text" 
                            id="searchInput"
                            placeholder="Search Name" 
                            class="form-control bg-black custom-input border-secondary w-50">
            </div>

            <div id="userList" class="user-list">
                <div class="user-empty">
                    <i class="fa fa-spinner fa-spin"></i>
                    Loading users…
                </div>
            </div>

        </div>
    </div>

    <!-- Toast -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="toast" class="toast align-items-center text-white border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/users.js"></script>
</body>
</html>
