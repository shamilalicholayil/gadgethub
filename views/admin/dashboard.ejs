<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
    <div class="d-flex">
        <%- include("../partials/adminSidebar") %>

        <div class="flex-grow-1 p-4">
            <div class="d-flex justify-content-between p-4">
                <h4 class="text-info fw-bold">Dashboard</h4>
                <span class="text-secondary">Welcome, Admin</span>
            </div>
            <div class="container">
                <!-- Stat Cards -->
                <div class="row g-4 mb-4">
                    <div class="col-md-3">
                        <div class="card glass p-4 text-center">
                            <i class="fa fa-users fa-2x text-info mb-3"></i>
                            <h4 class="text-secondary"><%= totalUsers %></h4>
                            <p class="fw-bold text-info mb-0">Total Users</p>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card glass p-4 text-center">
                            <i class="fa fa-box fa-2x text-info mb-3"></i>
                            <h4 class="text-secondary"><%= totalProducts %></h4>
                            <p class="fw-bold text-info mb-0">Total Products</p>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card glass p-4 text-center">
                            <i class="fa fa-shopping-cart fa-2x text-info mb-3"></i>
                            <h4 class="text-secondary"><%= totalOrders %></h4>
                            <p class="fw-bold text-info mb-0">Total Orders</p>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card glass p-4 text-center">
                            <i class="fa fa-indian-rupee-sign fa-2x text-info mb-3"></i>
                            <h4 class="text-secondary">₹<%= totalRevenue %></h4>
                            <p class="fw-bold text-info mb-0">Total Revenue</p>
                        </div>
                    </div>
                </div>

                <!-- Charts -->
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card glass p-4">
                            <h6 class="text-info mb-3">Monthly Revenue</h6>
                            <canvas id="revenueChart"></canvas>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card glass p-4">
                            <h6 class="text-info mb-3">Orders by Status</h6>
                            <canvas id="statusChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const monthlySales = <%- JSON.stringify(monthlySales) %>;
        const ordersByStatus = <%- JSON.stringify(ordersByStatus) %>;
    </script>
    <script src="/js/analytics.js"></script>
</body>
</html>