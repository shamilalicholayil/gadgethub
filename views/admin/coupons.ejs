    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Coupons</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
        <link href="/css/styles.css" rel="stylesheet">
    </head>
    <body>
        <div class="d-flex">
            <%- include("../partials/adminSidebar") %>

            <div class="flex-grow-1 p-4">
                <div class="d-flex justify-content-between align-items-center p-4">
                    <h4 class="text-info fw-bold">Coupons</h4>
                    <div class="d-flex justify-content-center gap-2">
                        <input type="text" 
                        id="searchInput"
                        placeholder="Search Code" 
                        class="form-control custom-input border-secondary w-50">
                        <button type="button" class="btn btn-info"
                                data-bs-toggle="modal" data-bs-target="#addCouponModal"
                                >+ Add Coupon</button>
                    </div>
                </div>

                <div class="container">
                    <table class="table table-responsive align-middle table-transparant table-hover">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Type</th>
                                <th>Value</th>
                                <th>Min Order</th>
                                <th>Expiry</th>
                                <th>Usage Limit</th>
                                <th>Used Count</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="couponTableBody">
                            <% if(coupons.length === 0) { %>
                                <tr>
                                    <td colspan="7" class="text-center py-3">Coupon not found.</td>
                                </tr>
                            <% } else { %>
                                <% coupons.forEach(coupon => { %>
                                    <tr>
                                        <td><%= coupon.code %></td>
                                        <td><%= coupon.discountType %></td>
                                        <td><%= coupon.discountValue %></td>
                                        <td><%= coupon.minOrderValue %></td>
                                        <td><%= new Date(coupon.expiryDate).toLocaleDateString("en-IN") %></td>
                                        <td><%= coupon.usageLimit %></td>
                                        <td><%= coupon.usedCount %></td>
                                        <td>
                                            <% if(coupon.isActive) { %>
                                                <span class="badge bg-success">Active</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">Inactive</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <button type="button" 
                                                    class="btn btn-sm btn-outline-info editBtn"
                                                    data-id="<%= coupon._id %>"
                                                    data-code="<%= coupon.code %>"
                                                    data-type="<%= coupon.discountType %>"
                                                    data-value="<%= coupon.discountValue %>"
                                                    data-min-order="<%= coupon.minOrderValue %>"
                                                    data-expiry="<%= coupon.expiryDate %>"
                                                    data-usage-limit="<%= coupon.usageLimit %>"
                                                    data-used-count="<%= coupon.usedCount %>">
                                                    <i class="fa fa-edit"></i>
                                            </button>
                                            <button type="button" 
                                                    class="btn btn-sm btn-outline-danger deleteBtn"
                                                    data-id="<%= coupon._id %>"
                                                    data-active="<%= coupon.isActive %>">
                                                <i class="fa fa-power-off"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Toast -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="toast" class="toast align-items-center text-white border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" 
                        data-bs-dismiss="toast">
                </button>
            </div>
        </div>
    </div>

        <!-- Add coupon Model -->
        <div class="modal fade" id="addCouponModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content glass-modal text-light">

                    <div class="modal-header border-0">
                        <h5 class="modal-title text-info fw-bold">
                            <i class="fa fa-gift me-2"></i>Add Coupon</h5>
                        <button type="button" class="btn-close btn-close-white"
                                data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <input type="text" 
                            id="couponCodeInput" 
                            class="form-control custom-input mb-3" 
                            placeholder="Coupon code">
                        <select id="couponType" class="form-control custom-input mb-3">
                            <option value="percent">Percent</option>
                            <option value="flat">Flat</option>
                        </select>
                        <input type="number"
                                id="couponValue"
                                class="form-control custom-input mb-3"
                                placeholder="Discount Value">
                        <input type="number"
                                id="couponMinOrder"
                                class="form-control custom-input mb-3"
                                placeholder="Min Order Value">
                        <input type="date"
                                class="form-control custom-input mb-3"
                                id="couponExpiry">
                        <input type="number"
                                id="couponUsageLimit"
                                class="form-control custom-input mb-3"
                                placeholder="Coupon Usage Limit">
                        <p id="couponError" class="text-danger mt-2 d-none"></p>
                    </div>

                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-info" 
                                id="saveCouponBtn">Save</button>
                    </div>

                </div>
            </div>
        </div>

        <!-- Edit Coupon Model -->
        <div class="modal fade" id="editCouponModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content bg-dark text-light">

                    <div class="modal-header">
                        <h5 class="modal-title">Edit Coupon</h5>
                        <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <input type="text"
                                id="editCouponCode"
                                class="form-control custom-input mb-3"
                                value="">
                        <select id="editCouponType" class="form-control custom-input mb-3">
                            <option value="percent">Percent</option>
                            <option value="flat">Flat</option>
                        </select>
                        <input type="number"
                                id="editCouponValue"
                                class="form-control custom-input mb-3"
                                value="">
                        <input type="number"
                                id="editCouponMinOrder"
                                class="form-control custom-input mb-3"
                                value="">
                        <input type="date"
                                class="form-control custom-input mb-3"
                                id="editCouponExpiry">
                        <input type="number"
                                id="editCouponUsageLimit"
                                class="form-control custom-input mb-3"
                                value="">
                        <p id="editCouponError" class="text-danger mt-2 d-none"></p>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-success"
                        id="saveEditCouponBtn">Save</button>
                    </div>

                </div>
            </div>
        </div>


        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="/js/coupon.js"></script>
    </body>
    </html>