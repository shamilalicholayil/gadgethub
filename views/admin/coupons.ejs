<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coupons — GadgetHub Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
    <link rel="stylesheet" href="/css/adminSidebar.css">
    <link href="/css/styles.css" rel="stylesheet">
</head>
<body>

    <div class="d-flex admin-layout">
        <%- include("../partials/adminSidebar") %>

        <div class="admin-content">

            <!-- Page header -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <h4 class="text-info fw-bold mb-0">Coupons</h4>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="d-flex justify-content-center gap-2">
                        <input type="text"
                               id="searchInput"
                               placeholder="Search code…"
                               class="form-control bg-black custom-input border-secondary w-50">
                    
                        <button type="button" class="btn btn-info"
                                data-bs-toggle="modal" data-bs-target="#addCouponModal">
                            <i class="fa fa-plus me-1"></i> Add Coupon
                        </button>
                    </div>
                </div>
            </div>

            <!-- Coupons table -->
            <div class="glass p-3 p-md-4">
                <div class="table-responsive">
                    <table class="table table-transparant table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Type</th>
                                <th>Value</th>
                                <th>Min Order</th>
                                <th>Expiry</th>
                                <th>Limit</th>
                                <th>Used</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="couponTableBody">
                            <% if(coupons.length === 0) { %>
                                <tr>
                                    <td colspan="9" class="text-center py-4 text-secondary">
                                        No coupons found.
                                    </td>
                                </tr>
                            <% } else { %>
                                <% coupons.forEach(coupon => { %>
                                <tr>
                                    <td><code class="text-info"><%= coupon.code %></code></td>
                                    <td><%= coupon.discountType %></td>
                                    <td><%= coupon.discountValue %></td>
                                    <td>₹<%= coupon.minOrderValue %></td>
                                    <td><%= new Date(coupon.expiryDate).toLocaleDateString("en-IN") %></td>
                                    <td><%= coupon.usageLimit %></td>
                                    <td><%= coupon.usedCount %></td>
                                    <td>
                                        <% if(coupon.isActive) { %>
                                            <span class="badge bg-success">Active</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Inactive</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-info editBtn"
                                                data-id="<%= coupon._id %>"
                                                data-code="<%= coupon.code %>"
                                                data-type="<%= coupon.discountType %>"
                                                data-value="<%= coupon.discountValue %>"
                                                data-min-order="<%= coupon.minOrderValue %>"
                                                data-expiry="<%= coupon.expiryDate %>"
                                                data-usage-limit="<%= coupon.usageLimit %>"
                                                data-used-count="<%= coupon.usedCount %>">
                                            <i class="fa fa-edit"></i>
                                        </button>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger deleteBtn"
                                                data-id="<%= coupon._id %>"
                                                data-active="<%= coupon.isActive %>">
                                            <i class="fa fa-power-off"></i>
                                        </button>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>

    <!-- Toast -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="toast" class="toast align-items-center text-white border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <!-- ── Add Coupon Modal ────────────────────────────────── -->
    <div class="modal fade" id="addCouponModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-modal text-light">

                <div class="modal-header border-0">
                    <h5 class="modal-title text-info fw-bold">
                        <i class="fa fa-ticket me-2"></i>Add Coupon
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="field-label">Coupon Code</label>
                            <input type="text" id="couponCodeInput"
                                   class="form-control custom-input"
                                   placeholder="e.g. SAVE20">
                        </div>
                        <div class="col-md-6">
                            <label class="field-label">Discount Type</label>
                            <select id="couponType" class="form-select custom-input">
                                <option value="percent">Percent (%)</option>
                                <option value="flat">Flat (₹)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="field-label">Discount Value</label>
                            <input type="number" id="couponValue"
                                   class="form-control custom-input"
                                   placeholder="e.g. 20">
                        </div>
                        <div class="col-md-6">
                            <label class="field-label">Min Order Value (₹)</label>
                            <input type="number" id="couponMinOrder"
                                   class="form-control custom-input"
                                   placeholder="e.g. 500">
                        </div>
                        <div class="col-md-6">
                            <label class="field-label">Usage Limit</label>
                            <input type="number" id="couponUsageLimit"
                                   class="form-control custom-input"
                                   placeholder="e.g. 100">
                        </div>
                        <div class="col-12">
                            <label class="field-label">Expiry Date</label>
                            <input type="date" id="couponExpiry"
                                   class="form-control custom-input">
                        </div>
                    </div>
                    <p id="couponError" class="text-danger mt-3 mb-0 d-none"></p>
                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-info" id="saveCouponBtn">
                        <i class="fa fa-save me-1"></i> Save Coupon
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- ── Edit Coupon Modal ───────────────────────────────── -->
    <div class="modal fade" id="editCouponModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-modal text-light">

                <div class="modal-header border-0">
                    <h5 class="modal-title text-info fw-bold">
                        <i class="fa fa-ticket me-2"></i>Edit Coupon
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="field-label">Coupon Code</label>
                            <input type="text" id="editCouponCode"
                                   class="form-control custom-input" value="">
                        </div>
                        <div class="col-md-6">
                            <label class="field-label">Discount Type</label>
                            <select id="editCouponType" class="form-select custom-input">
                                <option value="percent">Percent (%)</option>
                                <option value="flat">Flat (₹)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="field-label">Discount Value</label>
                            <input type="number" id="editCouponValue"
                                   class="form-control custom-input" value="">
                        </div>
                        <div class="col-md-6">
                            <label class="field-label">Min Order Value (₹)</label>
                            <input type="number" id="editCouponMinOrder"
                                   class="form-control custom-input" value="">
                        </div>
                        <div class="col-md-6">
                            <label class="field-label">Usage Limit</label>
                            <input type="number" id="editCouponUsageLimit"
                                   class="form-control custom-input" value="">
                        </div>
                        <div class="col-12">
                            <label class="field-label">Expiry Date</label>
                            <input type="date" id="editCouponExpiry"
                                   class="form-control custom-input">
                        </div>
                    </div>
                    <p id="editCouponError" class="text-danger mt-3 mb-0 d-none"></p>
                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-info" id="saveEditCouponBtn">
                        <i class="fa fa-save me-1"></i> Save Changes
                    </button>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/coupon.js"></script>
</body>
</html>
