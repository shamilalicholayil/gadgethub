<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products — GadgetHub Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
    <link rel="stylesheet" href="/css/adminSidebar.css">
    <link href="/css/styles.css" rel="stylesheet">
    <style>
        

        /* Search wrap */
        .search-wrap {
            position: relative;
            max-width: 260px;
            width: 100%;
        }
        .search-wrap i {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: #64748b;
            font-size: 13px;
            pointer-events: none;
        }
        .search-wrap input { padding-left: 36px; }
    </style>
</head>
<body>

    <div class="d-flex admin-layout">
        <%- include("../partials/adminSidebar") %>

        <div class="admin-content">

            <!-- Page header -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <h4 class="text-info fw-bold mb-0">Products</h4>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="d-flex justify-content-center gap-2">
                        <input type="text" 
                            id="searchInput"
                            placeholder="Search Name" 
                            class="form-control bg-black custom-input border-secondary w-50">
                        <button class="btn btn-info"
                                data-bs-toggle="modal"
                                data-bs-target="#addProductModal">
                            <i class="fa fa-plus me-1"></i> Add Product
                        </button>
                    </div>
                </div>
            </div>

            <!-- Products table -->
            <div class="glass p-3 p-md-4">
                <div class="table-responsive">
                    <table class="table table-transparant table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Brand</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="productTableBody">
                            <tr>
                                <td colspan="8" class="table-loading">
                                    <i class="fa fa-spinner fa-spin me-2"></i>Loading products…
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination -->
            <ul class="pagination justify-content-center mt-4" id="paginationContainer"></ul>

        </div>
    </div>

    <!-- Toast -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="toast" class="toast align-items-center text-white border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <!-- ── Add Product Modal ───────────────────────────────── -->
    <div class="modal fade" id="addProductModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content glass-modal text-light">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-info fw-bold">
                        <i class="fa fa-box me-2"></i>Add Product
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">

                    <h6 class="text-secondary mb-3">Basic Info</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="text" id="productName"
                                   class="form-control custom-input"
                                   placeholder="Product Name">
                        </div>
                        <div class="col-md-6">
                            <input type="text" id="productDesc"
                                   class="form-control custom-input"
                                   placeholder="Short Description">
                        </div>
                    </div>

                    <h6 class="text-secondary mt-4 mb-3">Pricing & Stock</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="number" id="productPrice"
                                   class="form-control custom-input"
                                   placeholder="Price (₹)">
                        </div>
                        <div class="col-md-6">
                            <input type="number" id="productStock"
                                   class="form-control custom-input"
                                   placeholder="Stock Quantity">
                        </div>
                    </div>

                    <h6 class="text-secondary mt-4 mb-3">Classification</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <select id="productBrand" class="form-select custom-input">
                                <option value="">Select Brand</option>
                                <% brands.forEach(brand => { %>
                                    <option value="<%= brand._id %>"><%= brand.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <select id="productCategory" class="form-select custom-input">
                                <option value="">Select Category</option>
                                <% categories.forEach(category => { %>
                                    <option value="<%= category._id %>"><%= category.name %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <h6 class="text-secondary mt-4 mb-3">Product Images <small class="text-muted">(1200×1200 px)</small></h6>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        <% for(let i = 0; i <= 4; i++) { %>
                        <div>
                            <input type="file" id="addImage_<%= i %>" name="image_<%= i %>" class="d-none" accept="image/*">
                            <label class="img-slot-label" for="addImage_<%= i %>">
                                <i class="fa fa-plus"></i>
                            </label>
                        </div>
                        <% } %>
                    </div>
                    <div id="productImagePreview" class="d-flex flex-wrap gap-2 mt-2"></div>
                    <p id="productError" class="text-danger mt-2 d-none"></p>

                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-info" id="saveProductBtn">
                        <i class="fa fa-save me-1"></i> Save Product
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Edit Product Modal ──────────────────────────────── -->
    <div class="modal fade" id="editProductModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content glass-modal text-light">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-info fw-bold">
                        <i class="fa fa-box me-2"></i>Edit Product
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">

                    <h6 class="text-secondary mb-3">Basic Info</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="text" id="editProductName"
                                   class="form-control custom-input" value="">
                        </div>
                        <div class="col-md-6">
                            <input type="text" id="editProductDesc"
                                   class="form-control custom-input" value="">
                        </div>
                    </div>

                    <h6 class="text-secondary mt-4 mb-3">Pricing & Stock</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="number" id="editProductPrice"
                                   class="form-control custom-input" value="">
                        </div>
                        <div class="col-md-6">
                            <input type="number" id="editProductStock"
                                   class="form-control custom-input" value="">
                        </div>
                    </div>

                    <h6 class="text-secondary mt-4 mb-3">Classification</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <select id="editProductBrand" class="form-select custom-input">
                                <option value="">Select Brand</option>
                                <% brands.forEach(brand => { %>
                                    <option value="<%= brand._id %>"><%= brand.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <select id="editProductCategory" class="form-select custom-input">
                                <option value="">Select Category</option>
                                <% categories.forEach(category => { %>
                                    <option value="<%= category._id %>"><%= category.name %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <h6 class="text-secondary mt-4 mb-3">Product Offer</h6>
                    <div class="row g-3 align-items-center">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="editHasOffer">
                                <label class="form-check-label text-secondary">Enable Offer</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <input type="number" id="editOfferPercent"
                                   class="form-control custom-input"
                                   placeholder="Offer % (e.g. 20)">
                        </div>
                    </div>

                    <h6 class="text-secondary mt-4 mb-3">Product Images <small class="text-muted">(1200×1200 px)</small></h6>
                    <% for(let i = 0; i <= 4; i++) { %>
                    <input type="file" id="editImage_<%= i %>" name="image_<%= i %>" class="d-none" accept="image/*">
                    <% } %>
                    <div id="editProductImagePreview" class="d-flex flex-wrap gap-2 mt-2"></div>
                    <p id="editProductError" class="text-danger mt-2 d-none"></p>

                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-info" id="saveEditProductBtn">
                        <i class="fa fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/product.js"></script>
</body>
</html>
