<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cart</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/shop.css">

  <style>
  </style>
</head>

<body>

  <%- include("./partials/userNavbar") %>

<div class="container py-5 mt-5">

  <div class="row g-4">

    <!-- LEFT SIDE -->
    <div class="col-lg-8">

      <h5 class="mb-4">Your Selection</h5>

      <!-- 🔴 EMPTY STATE (SHOW THIS WHEN CART EMPTY) -->
      <div id="emptyCart" class="card cart-glass p-5 text-center <%= items.length === 0 ? '' : 'd-none' %>">
        <h5 class="text-info">Your cart is empty 🛒</h5>
        <p class="text-secondary">Looks like you haven't added anything yet</p>
        <a href="/shop" class="btn btn-primary mt-3">Continue Shopping</a>
      </div>

      <!-- CART ITEMS -->
      <div id="cartItems">
          <% items.forEach(item => { %>
              <div class="card cart-glass p-3 mb-3">
                  <div class="d-flex justify-content-between align-items-center flex-wrap">
                      <div class="d-flex align-items-center gap-3">
                          <img src="<%= item.product.images[0].url %>" class="rounded" width="80">
                          <div>
                              <h6 class="text-info mb-1"><%= item.product.name %></h6>
                              <div class="d-flex align-items-center mt-2">
                                  <button class="btn btn-outline-info btn-qty" 
                                      data-id="<%= item.product._id %>"
                                      data-action="decrement">-</button>
                                  <span class="text-info mx-2"><%= item.quantity %></span>
                                  <button class="btn btn-outline-info btn-qty"
                                      data-id="<%= item.product._id %>"
                                      data-action="increment">+</button>
                              </div>
                          </div>
                      </div>
                      <div class="text-end">
                          <p class="mb-1 text-info">₹<%= item.product.finalPrice %></p>
                          <button class="btn btn-outline-danger remove-btn"
                              data-id="<%= item.product._id %>">Remove</button>
                      </div>
                  </div>
              </div>
          <% }) %>
      </div>

    </div>

    <!-- RIGHT SIDE (ALWAYS STAYS RIGHT) -->
    <div class="col-lg-4 ms-lg-auto">

      <div class="card cart-glass text-secondary p-4">

        <h6 class="text-info mb-4">Order Summary</h6>
        <% let total = items.reduce((sum, item) => sum + (item.product.finalPrice * item.quantity), 0); %>

        <div class="d-flex justify-content-between">
          <span>Subtotal</span>
          <span id="cartSubtotal"><%= total %></span>
        </div>

        <div class="d-flex justify-content-between mt-2">
          <span>Shipping</span>
          <span class="text-info">FREE</span>
        </div>

        <div class="d-flex justify-content-between mt-2">
          <span>Tax</span>
          <span>₹0</span>
        </div>

        <hr>

        <% let displayTotal = appliedCoupon ? total - appliedCoupon.discountAmount : total; %>
        <div class="d-flex justify-content-between mb-3">
          <strong>Total</strong>
          <strong class="text-info" id="cartTotal">₹<%= displayTotal %></strong>
        </div>

        <button class="btn btn-outline-secondary w-100 mb-2" 
                data-bs-toggle="modal" 
                data-bs-target="#couponModal">
            View Available Coupons
        </button>

        <input type="text" id="couponInput" 
            class="form-control custom-input mb-3 text-dark" 
            placeholder="Enter promo code"
            value="<%= appliedCoupon ? appliedCoupon.code : '' %>">

        <button id="applyCouponBtn" class="btn btn-outline-info w-100 mb-3">
            Apply Coupon
        </button>

        <p id="couponMessage" class="small <%= appliedCoupon ? 'text-success' : 'd-none' %>">
            <%= appliedCoupon ? `🎉 Coupon applied! You saved ₹${appliedCoupon.discountAmount}` : '' %>
        </p>

        <button class="btn checkout-btn w-100 py-2" onclick="window.location.href='/checkout'">
          Proceed to Checkout →
        </button>

      </div>

    </div>

  </div>

</div>

<%- include("./partials/userFooter") %>

<div class="modal fade" id="couponModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header border-0">
                <h5 class="modal-title text-info">Available Coupons</h5>
                <button type="button" class="btn-close btn-close-white" 
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="couponList">
                <p class="text-secondary text-center">Loading...</p>
            </div>
        </div>
    </div>
</div>

<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
<script src="/js/userCart.js"></script>

</body>
</html>