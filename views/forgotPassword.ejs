<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: radial-gradient(circle at top, #0f172a, #020617); min-height: 100vh; display: flex; align-items: center; }
        .card { background: rgba(17,28,46,0.85); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; }
        .form-control { background: #050b18; border: 1px solid #1e293b; color: #fff; }
        .form-control:focus { border-color: #38bdf8; box-shadow: none; color: #fff; }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4 text-light">
                <h5 class="text-info fw-bold mb-1">Forgot Password</h5>
                <p class="text-secondary small mb-4">Enter your email and we'll send a reset link.</p>

                <% if(locals.error) { %>
                    <div class="alert alert-danger py-2"><%= error %></div>
                <% } %>
                <% if(locals.message) { %>
                    <div class="alert alert-success py-2"><%= message %></div>
                <% } %>

                <form action="/forgot-password" method="POST">
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Email Address</label>
                        <input type="email" name="email" class="form-control text-dark" placeholder="you@example.com" required>
                    </div>
                    <button type="submit" class="btn btn-info w-100">Send Reset Link</button>
                </form>

                <p class="text-center text-secondary small mt-3">
                    Remember your password? <a href="/login" class="text-info">Login</a>
                </p>
            </div>
        </div>
    </div>
</div>
</body>
</html>