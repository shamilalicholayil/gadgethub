<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> — GadgetHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/userProduct.css">
</head>
<body>

<%- include("partials/userNavbar") %>

<!-- ══════════════════════════════════════════
     PRODUCT HERO
══════════════════════════════════════════ -->
<section class="pd-section">
    <div class="container">
        <div class="pd-grid">

            <!-- ── LEFT: Image column ── -->
            <div class="pd-image-col">

                <!-- Thumbnail strip -->
                <div class="thumb-strip" role="list" aria-label="Product images">
                    <% product.images.forEach((image, index) => { %>
                    <button class="thumb-btn <%= index === 0 ? 'active' : '' %>"
                            data-url="<%= image.url %>"
                            role="listitem"
                            aria-label="Product image <%= index + 1 %>">
                        <img src="<%= image.url %>" alt="Product view <%= index + 1 %>" loading="lazy">
                    </button>
                    <% }) %>
                </div>

                <!-- Main image + zoom -->
                <div class="main-img-wrap" id="imgContainer">
                    <div class="main-img-bg"></div>
                    <img id="mainImage" src="<%= product.images[0].url %>" alt="<%= product.name %>">
                    <div id="lens"></div>
                    <div id="zoomBox"></div>
                </div>

            </div>

            <!-- ── RIGHT: Details column ── -->
            <div class="pd-info-col">

                <!-- Brand + breadcrumb -->
                <div class="pd-brand-row">
                    

                    <a href="/shop" class="pd-back">
                        <i class="fa fa-arrow-left" aria-hidden="true"></i> Back to shop
                    </a>
                </div>

                <!-- Product name -->
                <h1 class="pd-name mt-4"><%= product.name %></h1>
                <span class="pd-brand"><%= product.brand.name %></span>

                <!-- Rating preview (static — replace with real data if available) -->
                <div class="pd-rating-row">
                    <div class="stars" aria-label="<%= reviews.length > 0 ? (reviews.reduce((a,r) => a + r.rating, 0) / reviews.length).toFixed(1) : 'No' %> stars">
                        <% 
                           const avg = reviews.length > 0
                               ? reviews.reduce((a,r) => a + r.rating, 0) / reviews.length
                               : 0;
                           for(let i = 1; i <= 5; i++) { %>
                            <i class="fa fa-star <%= i <= Math.round(avg) ? 'star-filled' : 'star-empty' %>" aria-hidden="true"></i>
                        <% } %>
                    </div>
                    <span class="pd-review-count">
                        <%= reviews.length %> <%= reviews.length === 1 ? 'review' : 'reviews' %>
                    </span>
                </div>

                <!-- Price block -->
                <div class="pd-price-block">
                    <span class="pd-final-price">₹<%= product.finalPrice.toLocaleString('en-IN') %></span>
                    <% if(product.hasOffer) { %>
                    <span class="pd-original-price">₹<%= product.price.toLocaleString('en-IN') %></span>
                    <span class="pd-offer-badge">
                        <i class="fa fa-bolt" aria-hidden="true"></i>
                        <%= product.offerPercent %>% OFF
                    </span>
                    <% } %>
                </div>

                <!-- Stock badge -->
                <div class="pd-stock">
                    <% if(product.stock > 0) { %>
                    <span class="stock-badge stock-in">
                        <span class="stock-dot"></span>
                        In Stock · <%= product.stock %> units
                    </span>
                    <% } else { %>
                    <span class="stock-badge stock-out">
                        <span class="stock-dot"></span>
                        Out of Stock
                    </span>
                    <% } %>
                </div>

                <!-- Description -->
                <div class="pd-desc-card">
                    <p class="pd-desc-text"><%= product.description %></p>
                </div>

                <!-- Perks -->
                <div class="pd-perks">
                    <div class="perk-item">
                        <i class="fa fa-credit-card" aria-hidden="true"></i>
                        <span>20% off on selected bank cards</span>
                    </div>
                    <div class="perk-item">
                        <i class="fa fa-truck" aria-hidden="true"></i>
                        <span>Free shipping on orders above ₹999</span>
                    </div>
                    <div class="perk-item">
                        <i class="fa fa-rotate-left" aria-hidden="true"></i>
                        <span>7-day easy returns</span>
                    </div>
                </div>

                <!-- CTA buttons -->
                <div class="pd-cta-row">
                    <button class="pd-btn-cart"
                            id="addToCartBtn"
                            data-id="<%= product._id %>"
                            <% if(product.stock === 0) { %>disabled<% } %>>
                        <i class="fa fa-cart-shopping" aria-hidden="true"></i>
                        Add to Cart
                    </button>
                    <button class="pd-btn-wish addToWishlistBtn"
                            data-id="<%= product._id %>"
                            aria-label="Add to wishlist">
                        <i class="fa fa-heart" aria-hidden="true"></i>
                    </button>
                </div>

            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     PRODUCT DETAILS TAB SECTION
══════════════════════════════════════════ -->
<section class="pd-tabs-section">
    <div class="container">

        <!-- Tab nav -->
        <div class="pd-tab-nav" role="tablist">
            <button class="pd-tab active" data-tab="details" role="tab" aria-selected="true">
                Product Details
            </button>
            <button class="pd-tab" data-tab="reviews" role="tab" aria-selected="false">
                Reviews
                <span class="tab-count"><%= reviews.length %></span>
            </button>
        </div>

        <!-- Details panel -->
        <div class="pd-tab-panel active" id="tab-details" role="tabpanel">
            <div class="pd-detail-card">
                <p class="pd-desc-text"><%= product.description %></p>
            </div>
        </div>

        <!-- Reviews panel -->
        <div class="pd-tab-panel" id="tab-reviews" role="tabpanel">

            <% if(reviews.length === 0) { %>
            <div class="pd-empty-reviews">
                <i class="fa fa-comment-slash" aria-hidden="true"></i>
                <p>No reviews yet. Be the first to review!</p>
            </div>
            <% } else { %>
            <div class="reviews-list">
                <% reviews.forEach(review => { %>
                <div class="review-card">
                    <div class="review-header">
                        <div class="review-avatar" aria-hidden="true">
                            <%= review.user.name.charAt(0).toUpperCase() %>
                        </div>
                        <div class="review-meta">
                            <span class="review-author"><%= review.user.name %></span>
                            <span class="review-date"><%= review.createdAt.toDateString() %></span>
                        </div>
                        <div class="review-stars" aria-label="<%= review.rating %> out of 5 stars">
                            <% for(let i = 1; i <= 5; i++) { %>
                            <i class="fa fa-star <%= i <= review.rating ? 'star-filled' : 'star-empty' %>" aria-hidden="true"></i>
                            <% } %>
                        </div>
                    </div>
                    <p class="review-comment"><%= review.comment %></p>
                </div>
                <% }) %>
            </div>
            <% } %>

            <!-- Write a review -->
            <% if(user) { %>
            <div class="review-form-card">
                <h6 class="review-form-title">
                    <i class="fa fa-pen-to-square" aria-hidden="true"></i>
                    Write a Review
                </h6>

                <!-- Star picker -->
                <div class="star-picker mb-4" aria-label="Select rating">
                    <% for(let i = 1; i <= 5; i++) { %>
                    <button class="star-pick-btn" data-val="<%= i %>" type="button" aria-label="<%= i %> stars">
                        <i class="fa fa-star" aria-hidden="true"></i>
                    </button>
                    <% } %>
                    <input type="hidden" id="reviewRating" value="">
                </div>

                <div class="mb-3">
                    <label class="gh-label" for="reviewComment">Your comment</label>
                    <textarea id="reviewComment" rows="4"
                              class="gh-textarea"
                              placeholder="Share your experience with this product…"></textarea>
                </div>

                <button id="submitReview" class="pd-btn-cart" data-id="<%= product._id %>">
                    <i class="fa fa-paper-plane" aria-hidden="true"></i>
                    Submit Review
                </button>
            </div>
            <% } else { %>
            <div class="review-login-prompt">
                <i class="fa fa-lock" aria-hidden="true"></i>
                <span><a href="/login">Log in</a> to write a review</span>
            </div>
            <% } %>
        </div>

    </div>
</section>

<!-- Toast -->
<div class="gh-toast-wrap">
    <div id="toast" class="toast align-items-center text-white border-0" role="alert" aria-live="assertive">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<%- include("./partials/userFooter") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script src="/js/userProduct.js"></script>
</body>
</html>
