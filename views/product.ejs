<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/shop.css">
</head>
<body>

<%- include("partials/userNavbar") %>

<div class="container py-5">
    <div class="row g-5">

        <div class="col-lg-6">
            <div class="image-section">

                <div class="thumbnail-row">
                    <% product.images.forEach((image, index) => { %>
                        <img src="<%= image.url %>"
                             class="<%= index === 0 ? 'active' : '' %>"
                             data-url="<%= image.url %>">
                    <% }) %>
                </div>

                <div id="imgContainer">
                    <img id="mainImage" src="<%= product.images[0].url %>">
                    <div id="lens"></div>
                    <div id="zoomBox"></div>
                </div>

            </div>
        </div>

        <div class="col-lg-6">
            <p class="text-info mb-1 small text-uppercase fw-bold"><%= product.brand.name %></p>
            <h1 class="fw-bold mb-3"><%= product.name %></h1>

            <div class="d-flex align-items-center gap-3 mb-4">
                <% if(product.hasOffer) { %>
                    <span class="text-secondary text-decoration-line-through me-2">₹<%= product.price %></span>
                <% } %>
                <span class="price">₹<%= product.finalPrice %></span>
                <% if(product.stock > 0) { %>
                    <span class="badge bg-success">In Stock (<%= product.stock %>)</span>
                <% } else { %>
                    <span class="badge bg-danger">Out of Stock</span>
                <% } %>
            </div>

            <div class="glass p-3 mb-4">
                <p class="text-secondary mb-0"><%= product.description %></p>
            </div>

            <div class="glass p-3 mb-4">
                <small class="d-block mb-1">🎁 20% off on selected bank cards</small>
                <small class="d-block">🚚 Free shipping on orders above ₹999</small>
            </div>

            <div class="d-flex gap-3 flex-wrap">
                <button class="btn btn-gradient px-4 text-white"
                        id="addToCartBtn"
                        data-id="<%= product._id %>"
                        <% if(product.stock === 0) { %>disabled<% } %>>
                    <i class="fa fa-cart-shopping me-2"></i>Add to Cart
                </button>
                <button class="btn btn-sm btn-outline-danger addToWishlistBtn" data-id="<%= product._id %>">
                    <i class="fa fa-heart"></i>
                </button>
            </div>
        </div>

    </div>
</div>

<div class="container pb-5">
    <div class="row">
        <div class="col-lg-8">
            <h4 class="section-title mb-3">PRODUCT DETAILS</h4>
            <div class="glass p-4">
                <p class="text-secondary mb-0"><%= product.description %></p>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <h4 class="section-title mb-3">REVIEWS</h4>
    <% if(reviews.length === 0) { %>
        <div class="glass p-4 mt-3">
            <p class="text-secondary mb-0">No reviews yet. Be the first!</p>
        </div>
    <% } else { %>
    <% reviews.forEach(review => { %>
            <div class="glass p-4 mt-3">
                <div class="d-flex justify-content-between">
                    <strong><%= review.user.name %> ⭐ <%= review.rating %>/5</strong>
                    <small class="text-secondary"><%= review.createdAt.toDateString() %></small>
                </div>
                <p class="text-secondary mt-2 mb-0"><%= review.comment %></p>
            </div>
        <% }) %>
    <% } %>

    <!-- Review Form -->
    <% if(user) { %>
        <div class="glass p-4 mt-4">
            <h6 class="text-info mb-3">Write a Review</h6>
            <div class="mb-3">
                <label class="text-secondary small mb-1">Rating (1–5)</label>
                <input type="number" id="reviewRating" min="1" max="5"
                       class="form-control custom-input border-secondary">
            </div>
            <div class="mb-3">
                <label class="text-secondary small mb-1">Comment</label>
                <textarea id="reviewComment" rows="3"
                          class="form-control custom-input border-secondary"></textarea>
            </div>
            <button id="submitReview" class="btn btn-gradient text-white px-4"
                    data-id="<%= product._id %>">
                Submit Review
            </button>
        </div>
    <% } %>

</div>

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
    <div id="toast" class="toast align-items-center text-white border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" 
                    data-bs-dismiss="toast">
            </button>
        </div>
    </div>
</div>

<%- include("./partials/userFooter") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/userProduct.js"></script>
</body>
</html>