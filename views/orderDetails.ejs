<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/shop.css">
</head>
<body>

<%- include("partials/userNavbar") %>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="text-info fw-bold mb-0">Order Details</h4>
        <a href="/orders" class="btn btn-outline-secondary btn-sm">← Back to Orders</a>
    </div>

    <div class="row g-4">

        <!-- LEFT: Items -->
        <div class="col-lg-8">
            <div class="glass p-4 mb-4">
                <h6 class="text-info mb-3">Items Ordered</h6>
                <% order.items.forEach(item => { %>
                    <div class="d-flex gap-3 align-items-center mb-3">
                        <img src="<%= item.product.images[0].url %>"
                             width="70" height="70"
                             style="object-fit:cover;border-radius:8px">
                        <div class="flex-grow-1">
                            <p class="mb-0 fw-bold"><%= item.product.name %></p>
                            <small class="text-secondary">
                                Qty: <%= item.quantity %> × ₹<%= item.price %>
                            </small>
                        </div>
                        <p class="mb-0 fw-bold">₹<%= item.quantity * item.price %></p>
                    </div>
                <% }) %>
            </div>

            <!-- Delivery Address -->
            <div class="glass p-4">
                <h6 class="text-info mb-3">Delivery Address</h6>
                <p class="mb-1 fw-bold"><%= order.address.fullName %></p>
                <p class="text-secondary small mb-1">
                    <%= order.address.address %>, <%= order.address.city %>,
                    <%= order.address.state %> - <%= order.address.pincode %>
                </p>
                <p class="text-secondary small mb-0">📞 <%= order.address.phone %></p>
            </div>
        </div>

        <!-- RIGHT: Summary -->
        <div class="col-lg-4">
            <div class="glass p-4 mb-4">
                <h6 class="text-info mb-3">Order Summary</h6>
                <p class="text-secondary small mb-1">
                    Order ID: <span class="text-white">#<%= order._id %></span>
                </p>
                <p class="text-secondary small mb-1">
                    Date: <%= order.createdAt.toDateString() %>
                </p>
                <p class="text-secondary small mb-1">
                    Payment: <%= order.paymentMethod.toUpperCase() %>
                </p>
                <p class="text-secondary small mb-3">
                    Payment Status:
                    <span class="badge <%= order.paymentStatus === 'paid' ? 'bg-success' : 'bg-warning text-dark' %>">
                        <%= order.paymentStatus.toUpperCase() %>
                    </span>
                </p>
                <hr class="border-secondary">
                <div class="d-flex justify-content-between fw-bold">
                    <span>Total</span>
                    <span class="text-info">₹<%= order.totalAmount %></span>
                </div>
            </div>

            <!-- Status + Actions -->
            <div class="glass p-4">
                <h6 class="text-info mb-3">Order Status</h6>
                <span class="badge fs-6 mb-3
                    <% if(order.orderStatus === 'delivered') { %>bg-success
                    <% } else if(order.orderStatus === 'cancelled') { %>bg-danger
                    <% } else if(order.orderStatus === 'returned') { %>bg-secondary
                    <% } else { %>bg-warning text-dark<% } %>">
                    <%= order.orderStatus.toUpperCase() %>
                </span>

                <% if(order.orderStatus === 'pending' || order.orderStatus === 'processing') { %>
                    <button class="btn btn-outline-danger w-100 mt-2" id="cancelBtn"
                            data-id="<%= order._id %>">
                        Cancel Order
                    </button>
                <% } %>

                <% if(order.orderStatus === 'delivered') { %>
                    <button class="btn btn-outline-warning w-100 mt-2" id="returnBtn"
                            data-id="<%= order._id %>">
                        Return Order
                    </button>
                <% } %>
            </div>
        </div>

    </div>
</div>

<%- include("./partials/userFooter") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/orderDetails.js"></script>
</body>
</html>