<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: radial-gradient(circle at top, #0f172a, #020617); min-height: 100vh; display: flex; align-items: center; }
        .card { background: rgba(17,28,46,0.85); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; }
        .form-control { background: #050b18; border: 1px solid #1e293b; color: #fff; }
        .form-control:focus { border-color: #38bdf8; box-shadow: none; color: #fff; }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4 text-light">
                <h5 class="text-info fw-bold mb-1">Reset Password</h5>
                <p class="text-secondary small mb-4">Enter your new password below.</p>

                <% if(locals.error) { %>
                    <div class="alert alert-danger py-2"><%= error %></div>
                <% } %>

                <form action="/reset-password/<%= token %>" method="POST" id="resetForm" novalidate>
                    <div class="mb-1">
                        <label class="form-label text-secondary small">New Password</label>
                        <input type="password" id="password" name="password"
                               class="form-control" placeholder="Min 8 characters">
                    </div>
                    <span class="text-danger small d-block mb-3" id="passwordError"></span>

                    <div class="mb-1">
                        <label class="form-label text-secondary small">Confirm Password</label>
                        <input type="password" id="confirmPassword"
                               class="form-control" placeholder="Repeat password">
                    </div>
                    <span class="text-danger small d-block mb-4" id="confirmPasswordError"></span>

                    <button type="submit" class="btn btn-info w-100">Reset Password</button>
                </form>

                <p class="text-center text-secondary small mt-3">
                    <a href="/login" class="text-info">Back to Login</a>
                </p>
            </div>
        </div>
    </div>
</div>
<script src="/js/resetPasword.js"></script>
</body>
</html>