<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/shop.css">
</head>
<body>
    <%- include("partials/userNavbar") %>

    <div class="container py-5">
        <div class="row g-4">

            <!-- LEFT: User Info -->
            <div class="col-lg-4">
                <div class="glass p-4">
                    <div class="text-center mb-4">
                        <i class="fa fa-user-circle fa-4x text-info"></i>
                        <h5 class="mt-3 fw-bold"><%= userData.name %></h5>
                        <p class="text-secondary small"><%= userData.email %></p>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-secondary small fw-bold">FULL NAME</span>
                            <span class="text-info small"><%= userData.name %></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-secondary small fw-bold">EMAIL</span>
                            <span class="text-info small"><%= userData.email %></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-outline-info btn-sm w-100"
                                data-bs-toggle="modal" data-bs-target="#editProfileModal">
                            <i class="fa fa-pen me-1"></i>Edit Profile
                        </button>
                        <button class="btn btn-outline-secondary btn-sm w-100"
                                data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                            <i class="fa fa-lock me-1"></i>Password
                        </button>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Addresses -->
            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-info fw-bold mb-0">My Addresses</h5>
                    <button class="btn btn-outline-info btn-sm"
                            data-bs-toggle="modal" data-bs-target="#addAddressModal">
                        <i class="fa fa-plus me-1"></i>Add Address
                    </button>
                </div>

                <% if(addresses.length === 0) { %>
                    <div class="glass p-4 text-secondary">No addresses saved yet.</div>
                <% } else { %>
                    <% addresses.forEach(addr => { %>
                        <div class="glass p-4 mb-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong><%= addr.fullName %></strong>
                                    <% if(addr.isDefault) { %>
                                        <span class="badge bg-info ms-2">Default</span>
                                    <% } %>
                                    <p class="text-secondary small mb-1 mt-1">
                                        <%= addr.address %>, <%= addr.city %>,
                                        <%= addr.state %> - <%= addr.pincode %>
                                    </p>
                                    <p class="text-secondary small mb-0">📞 <%= addr.phone %></p>
                                </div>
                                <div class="d-flex gap-2 flex-wrap justify-content-end">
                                    <% if(!addr.isDefault) { %>
                                        <button class="btn btn-sm btn-outline-secondary setDefaultBtn"
                                                data-id="<%= addr._id %>">
                                            Set Default
                                        </button>
                                    <% } %>
                                    <button class="btn btn-sm btn-outline-info editAddressBtn"
                                            data-id="<%= addr._id %>"
                                            data-fullname="<%= addr.fullName %>"
                                            data-phone="<%= addr.phone %>"
                                            data-address="<%= addr.address %>"
                                            data-city="<%= addr.city %>"
                                            data-state="<%= addr.state %>"
                                            data-pincode="<%= addr.pincode %>">
                                        <i class="fa fa-pen"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger deleteAddressBtn"
                                            data-id="<%= addr._id %>">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

        </div>
    </div>

    <!-- Edit Profile Modal -->
    <div class="modal fade" id="editProfileModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content bg-dark">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-info">Edit Profile</h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="text-secondary small mb-1">Full Name</label>
                    <input type="text" id="editName"
                        class="form-control custom-input border-secondary mb-3"
                        value="<%= userData.name %>">
                    <label class="text-secondary small mb-1">Email</label>
                    <input type="email" id="editEmail"
                        class="form-control custom-input border-secondary"
                        value="<%= userData.email %>">
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-gradient text-white" id="saveProfileBtn">
                        Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Change Password Modal -->
    <div class="modal fade" id="changePasswordModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content bg-dark">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-info">Change Password</h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="text-secondary small mb-1">Current Password</label>
                    <input type="password" id="currentPassword"
                        class="form-control custom-input border-secondary mb-3">
                    <label class="text-secondary small mb-1">New Password</label>
                    <input type="password" id="newPassword"
                        class="form-control custom-input border-secondary mb-3">
                    <label class="text-secondary small mb-1">Confirm New Password</label>
                    <input type="password" id="confirmPassword"
                        class="form-control custom-input border-secondary">
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-gradient text-white" id="savePasswordBtn">
                        Update Password
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Address Modal -->
    <div class="modal fade" id="addAddressModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content bg-dark">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-info">Add New Address</h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="text" id="addrFullName" placeholder="Full Name"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="addrPhone" placeholder="Phone"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="addrLine" placeholder="Address"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="addrCity" placeholder="City"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="addrState" placeholder="State"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="addrPincode" placeholder="Pincode"
                        class="form-control custom-input border-secondary">
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-gradient text-white" id="saveAddressBtn">
                        Save Address
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Address Modal -->
    <div class="modal fade" id="editAddressModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content bg-dark">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-info">Edit Address</h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editAddrId">
                    <input type="text" id="editAddrFullName" placeholder="Full Name"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="editAddrPhone" placeholder="Phone"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="editAddrLine" placeholder="Address"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="editAddrCity" placeholder="City"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="editAddrState" placeholder="State"
                        class="form-control custom-input border-secondary mb-3">
                    <input type="text" id="editAddrPincode" placeholder="Pincode"
                        class="form-control custom-input border-secondary">
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-gradient text-white" id="updateAddressBtn">
                        Update Address
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="toast" class="toast align-items-center text-white border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <%- include("./partials/userFooter") %>
    <script src="/js/userProfile.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>