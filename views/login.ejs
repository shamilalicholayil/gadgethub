<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="/css/userLogin.css" rel="stylesheet">
</head>
<body class="bg-dark text-white">
    <div class="page">
        <div class="header">
            <div class="logo-icon">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <rect x="1" y="1" width="5" height="5" rx="1.5" fill="white"/>
                <rect x="8" y="1" width="5" height="5" rx="1.5" fill="white" opacity="0.6"/>
                <rect x="1" y="8" width="5" height="5" rx="1.5" fill="white" opacity="0.6"/>
                <rect x="8" y="8" width="5" height="5" rx="1.5" fill="white" opacity="0.3"/>
            </svg>
            </div>
            <span class="logo-text">GADGETHUB</span>
        </div>

        <div class="main">
            <div class="card">
            <div class="tab-row">
                <a href="#" class="tab active">LOGIN</a>
                <a href="/register" class="tab inactive">REGISTER</a>
            </div>
            <form action="/login" method="POST" id="loginForm" novalidate>
                <label class="field-label">EMAIL ADDRESS</label>
                <div class="input-wrap">
                    <span class="input-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/>
                    </svg>
                    </span>
                    <input type="email" id="email" name="email" placeholder="name@example.com" />
                </div>
                <div class="error-text" id="emailErr"></div>

                <label class="field-label">PASSWORD</label>
                <div class="input-wrap">
                    <span class="input-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    </span>
                    <input type="password" id="pwInput" name="password" placeholder="••••••••" />
                    <button class="eye-btn" onclick="togglePw()" id="eyeBtn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="eyeIcon">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                    </button>
                </div>
                <div class="error-text" id="pwErr"></div>

                <% if(error) { %>
                    <p class="text-danger"><%= error %></p>
                <% } %>

                <a class="forgot" href="/forgot-Password">Forgot password?</a>

                <button type="submit" class="btn-login">SIGN IN</button>
                </div>
            </form>
        </div>

        <div class="footer">
            <span class="footer-brand">© 2024 GADGETHUB OBSIDIAN</span>
            <div class="footer-links">
            <span>PRIVACY</span>
            <span>TERMS</span>
            <span>SUPPORT</span>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/userLogin.js"></script>
</body>
</html>