<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — GadgetHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="/css/userLogin.css" rel="stylesheet">
    <link href="/css/userFooter.css" rel="stylesheet">
</head>
<body>

    <!-- Header -->
    <header class="gh-header">
        <div class="gh-logo-mark" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
        </div>
        <span class="gh-logo-text">GADGETHUB</span>
    </header>

    <!-- Main -->
    <main class="gh-main">
        <div class="gh-card">

            <!-- Tabs -->
            <div class="gh-tabs" role="tablist">
                <span class="gh-tab active" role="tab" aria-selected="true">LOGIN</span>
                <a href="/register" class="gh-tab inactive" role="tab" aria-selected="false">REGISTER</a>
            </div>

            <!-- Form -->
            <form action="/login" method="POST" id="loginForm" novalidate>

                <!-- Server-side EJS error -->
                <% if(error) { %>
                <div class="gh-server-error" role="alert">
                    <i class="fa fa-circle-exclamation" aria-hidden="true"></i>
                    <span><%= error %></span>
                </div>
                <% } %>

                <!-- Email -->
                <label class="gh-label" for="email">EMAIL ADDRESS</label>
                <div class="gh-input-group" id="emailGroup">
                    <span class="gh-input-icon">
                        <i class="fa fa-envelope" aria-hidden="true"></i>
                    </span>
                    <input type="email" id="email" name="email"
                           placeholder="name@example.com"
                           autocomplete="email"
                           aria-describedby="emailError">
                </div>
                <span class="gh-error" id="emailError" role="alert" aria-live="polite"></span>

                <!-- Password -->
                <label class="gh-label" for="password">PASSWORD</label>
                <div class="gh-input-group" id="passwordGroup">
                    <span class="gh-input-icon">
                        <i class="fa fa-lock" aria-hidden="true"></i>
                    </span>
                    <input type="password" id="password" name="password"
                           placeholder="••••••••"
                           autocomplete="current-password"
                           aria-describedby="passwordError">
                    <button type="button" class="gh-eye-btn" id="eyeBtn" aria-label="Show password">
                        <i class="fa fa-eye" id="eyeIcon" aria-hidden="true"></i>
                    </button>
                </div>
                <span class="gh-error" id="passwordError" role="alert" aria-live="polite"></span>

                <!-- Forgot -->
                <a href="/forgot-Password" class="gh-forgot">Forgot password?</a>

                <!-- Submit -->
                <button type="submit" class="gh-btn">SIGN IN</button>
            </form>


        </div>
    </main>

    <!-- Footer -->
    <%- include("./partials/userFooter") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/userLogin.js"></script>

</body>
</html>
