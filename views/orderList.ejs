<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/shop.css">
</head>
<body>

<%- include("partials/userNavbar") %>

<div class="container py-5">
    <h4 class="text-info fw-bold mb-4">My Orders</h4>

    <% if(orders.length === 0) { %>
        <div class="glass p-5 text-center text-secondary">
            <i class="fa fa-box-open fa-3x mb-3"></i>
            <p>No orders yet. <a href="/shop" class="text-info">Start shopping</a></p>
        </div>
    <% } else { %>
        <% orders.forEach(order => { %>
            <div class="glass p-4 mb-3">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                    
                    <div>
                        <p class="text-secondary small mb-1">
                            Order ID: <span class="text-info">#<%= order._id %></span>
                        </p>
                        <p class="text-secondary small mb-1">
                            Date: <%= order.createdAt.toDateString() %>
                        </p>
                        <p class="text-secondary small mb-0">
                            Items: <%= order.items.length %>
                        </p>
                    </div>

                    <div class="text-end">
                        <p class="fw-bold text-white mb-1">₹<%= order.totalAmount %></p>
                        <span class="badge mb-2
                            <% if(order.orderStatus === 'delivered') { %>bg-success
                            <% } else if(order.orderStatus === 'cancelled') { %>bg-danger
                            <% } else if(order.orderStatus === 'returned') { %>bg-secondary
                            <% } else { %>bg-warning text-dark<% } %>">
                            <%= order.orderStatus.toUpperCase() %>
                        </span>
                        <br>
                        <a href="/orders/<%= order._id %>" class="btn btn-outline-info btn-sm mt-1">
                            View Details
                        </a>
                    </div>

                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<%- include("./partials/userFooter") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>