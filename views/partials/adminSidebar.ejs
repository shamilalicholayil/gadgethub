<!-- Hamburger toggle — visible only on mobile -->
<button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
    <i class="fa-solid fa-bars"></i>
</button>

<!-- Overlay — tapping it closes sidebar on mobile -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- SIDEBAR -->
<div class="sidebar glass d-flex flex-column p-4" id="adminSidebar">

    <!-- LOGO -->
    <div class="sidebar-logo mb-5">
        <h3 class="fw-bold lh-sm mb-0">
            <span class="text-info">GadgetHub</span><br>
            <span class="text-white">Admin</span>
        </h3>
    </div>

    <!-- NAVIGATION -->
    <nav class="nav flex-column gap-2">

        <a href="/admin/dashboard" class="sidebar-link <%= currentPage === 'dashboard' ? 'active' : '' %>">
            <i class="fa-solid fa-chart-line"></i>
            <span>Dashboard</span>
        </a>

        <a href="/admin/users" class="sidebar-link <%= currentPage === 'users' ? 'active' : '' %>">
            <i class="fa-solid fa-users"></i>
            <span>Users</span>
        </a>

        <a href="/admin/brands" class="sidebar-link <%= currentPage === 'brands' ? 'active' : '' %>">
            <i class="fa-solid fa-tag"></i>
            <span>Brands</span>
        </a>

        <a href="/admin/categories" class="sidebar-link <%= currentPage === 'categories' ? 'active' : '' %>">
            <i class="fa-solid fa-layer-group"></i>
            <span>Categories</span>
        </a>

        <a href="/admin/products" class="sidebar-link <%= currentPage === 'products' ? 'active' : '' %>">
            <i class="fa-solid fa-box"></i>
            <span>Products</span>
        </a>

        <a href="/admin/coupons" class="sidebar-link <%= currentPage === 'coupons' ? 'active' : '' %>">
            <i class="fa-solid fa-ticket"></i>
            <span>Coupons</span>
        </a>

        <a href="/admin/orders" class="sidebar-link <%= currentPage === 'orders' ? 'active' : '' %>">
            <i class="fa-solid fa-bag-shopping"></i>
            <span>Orders</span>
        </a>

    </nav>

    <!-- PUSH LOGOUT DOWN -->
    <div class="mt-auto pt-4">
        <hr class="border-secondary">
        <a href="/admin/logout" class="sidebar-link logout-link">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Logout</span>
        </a>
    </div>

</div>

<script>
    const toggle  = document.getElementById('sidebarToggle');
    const sidebar = document.getElementById('adminSidebar');
    const overlay = document.getElementById('sidebarOverlay');

    toggle.addEventListener('click', () => {
        sidebar.classList.toggle('open');
        overlay.classList.toggle('visible');
    });
    overlay.addEventListener('click', () => {
        sidebar.classList.remove('open');
        overlay.classList.remove('visible');
    });
</script>
